{
  "name": "mindcare-ai",
  "version": "1.0.0",
  "description": "AI-powered student mental health & stress support system — full-stack app with PostgreSQL, JWT auth, and Claude-generated recommendations.",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client:install": "npm install --prefix client-react",
    "client:dev": "npm run dev --prefix client-react",
    "client:build": "npm run build --prefix client-react",
    "dev:all": "concurrently \"npm run dev\" \"npm run client:dev\"",
    "seed": "node server/seed.js",
    "check-setup": "node server/check-setup.js",
    "test": "node test/run-all.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
