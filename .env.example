# ===== PostgreSQL =====
# Local: postgres://postgres:yourpassword@localhost:5432/mindcare
# Render: copy the "External Database URL" from your Render Postgres dashboard
DATABASE_URL=postgres://postgres:yash2007@localhost:5432/mindcare


# Render's managed Postgres requires SSL. Local Postgres usually doesn't.
# Set to "false" only when connecting to a local database without SSL.
DATABASE_SSL=false

# ===== Auth =====
# Use a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=JWT_SECRET=mindcare-yashwanth-tjs-secret-key-2026-abc123xyz
JWT_EXPIRES_IN=7d

# ===== AI (Google Gemini — free tier) =====
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ===== Server =====
PORT=5000

# Set this to your deployed Vercel URL once you have it, e.g.
# https://mindcare-ai.vercel.app
# Leave blank for local dev — all origins are allowed when unset.
FRONTEND_URL=
